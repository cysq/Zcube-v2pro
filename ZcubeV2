/* ===== ANIMATION (浣跨敤requestAnimationFrame鏇夸唬setInterval) ===== */
function animReset(){
  animState.playing=false;animState.progress=0;
  if(animState.rafId){cancelAnimationFrame(animState.rafId);animState.rafId=null;}
  if(animState.timer){clearInterval(animState.timer);animState.timer=null;}
  $('playBtn').textContent='鈻�';updateAnimUI();requestRedraw();
}
function togPlay(){
  if(!result)return;
  animState.playing=!animState.playing;
  $('playBtn').textContent=animState.playing?'鈴�':'鈻�';
  if(animState.playing){
    if(animState.progress>=1)animState.progress=0;
    let last=performance.now();
    const tick=now=>{
      if(!animState.playing)return;
      const dt=(now-last)/1000;last=now;
      animState.progress+=dt*0.12*animState.speed;
      if(animState.progress>=1){animState.progress=1;animState.playing=false;$('playBtn').textContent='鈻�';}
      updateAnimUI();requestRedraw();
      if(animState.playing)animState.rafId=requestAnimationFrame(tick);
    };
    animState.rafId=requestAnimationFrame(tick);
  } else {if(animState.rafId){cancelAnimationFrame(animState.rafId);animState.rafId=null;}}
}
function animStep(dir){if(!result)return;const n=result.placed.length;if(!n)return;animState.progress=Math.max(0,Math.min(1,animState.progress+dir/n));updateAnimUI();requestRedraw();}
function seekStart(e){
