function switchV(v){
  document.querySelectorAll('.vt').forEach(t=>t.classList.toggle('on',t.dataset.v===v));
  document.querySelectorAll('.vp').forEach(p=>p.classList.toggle('on',p.id==='panel'+v.charAt(0).toUpperCase()+v.slice(1)));
