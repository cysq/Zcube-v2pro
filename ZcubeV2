      await new Promise(r=>requestAnimationFrame(()=>requestAnimationFrame(r)));
      try{screenshots.push(canvas.toDataURL('image/png'));}catch(e){screenshots.push('');}
    }else{
      screenshots.push('');
    }
  }

  // 鎭㈠鍘熺姸鎬�
  result=origResult;
  renderList=origRenderList;
  if(result){buildRenderList();resizeCanvas();drawScene();}

  // 鏋勫缓姣忛〉HTML
  function buildPageHTML(scheme,idx){
    const s=scheme.stats,cn=scheme.cn;
    const sm={};
    (scheme.placed||[]).forEach(p=>{
      const nm=p.n||'鏈煡';
      if(!sm[nm])sm[nm]={c:0,wt:0,vol:0,l:p.l||p.pos.w,w:p.w||p.pos.d,h:p.h||p.pos.h};
      sm[nm].c++;sm[nm].wt+=p.wt;sm[nm].vol+=p.pos.w*p.pos.h*p.pos.d;
    });

    const statsHTML=s?`<div style="display:flex;gap:8px;margin:8px 0">
