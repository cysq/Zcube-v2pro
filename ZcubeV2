/* ===== SMART PACKING ALGORITHM ===== */
// 鍒嗗眰鎵弿 + 澶氱瓥鐣ユ悳绱� + 鑷€傚簲鏂瑰悜 + 璐績鏈€浼樻斁缃�

function getOrientations(item){
  const all=[
    {k:'stand',w:item.l,h:item.h,d:item.w},
    {k:'standR',w:item.w,h:item.h,d:item.l},
    {k:'lay',w:item.l,h:item.w,d:item.h},
    {k:'layR',w:item.h,h:item.w,d:item.l},
    {k:'up',w:item.w,h:item.l,d:item.h},
    {k:'upR',w:item.h,h:item.l,d:item.w},
  ];
  // ni 寮哄埗浠呭簳闈㈡湞涓�
  if(item.ni) return [all[0],all[1]];
  // 鍏ㄥ眬鏀剧疆鏂瑰悜璁剧疆
  const go=getGlobalOrients();
  if(go.includes('smart')||!go.length) return all;
  const result=[];
  if(go.includes('stand')) result.push(all[0]);
  if(go.includes('standR')) result.push(all[1]);
  if(go.includes('lay')){result.push(all[2],all[3]);}
  if(go.includes('side')){result.push(all[4],all[5]);}
  return result.length?result:all;
}

function splitSpace(space,pos){
  const ns=[];
  const px=pos.x,py=pos.y,pz=pos.z;
  const pw=pos.w,ph=pos.h,pd=pos.d;
  const sx=space.x,sy=space.y,sz=space.z;
  const sw=space.w,sh=space.h,sd=space.d;
  if(sw-pw>10) ns.push({x:sx+pw,y:sy,z:sz,w:sw-pw,h:ph,d:pd});
  if(sd-pd>10) ns.push({x:sx,y:sy,z:sz+pd,w:sw,h:ph,d:sd-pd});
  if(sh-ph>10) ns.push({x:px,y:py+ph,z:pz,w:pw,h:sh-ph,d:pd});
  return ns;
}

function pruneSpaces(spaces){
  spaces=spaces.filter(s=>s.w>10&&s.h>10&&s.d>10);
  if(spaces.length<=1) return spaces;
  spaces.sort((a,b)=>(a.w*a.h*a.d)-(b.w*b.h*b.d));
  const alive=new Array(spaces.length).fill(true);
  let aliveCount=spaces.length;
  for(let i=0;i<spaces.length&&aliveCount>MAX_SPACES;i++){
    if(!alive[i])continue;
    for(let j=i+1;j<spaces.length;j++){
      if(!alive[j])continue;
      const a=spaces[i],b=spaces[j];
      if(b.x<=a.x&&b.y<=a.y&&b.z<=a.z&&
         b.x+b.w>=a.x+a.w&&b.y+b.h>=a.y+a.h&&b.z+b.d>=a.z+a.d){
        alive[i]=false;aliveCount--;break;
      }
    }
  }
  if(aliveCount>MAX_SPACES){
    const indexed=spaces.map((s,i)=>({i,vol:s.w*s.h*s.d}));
    indexed.sort((a,b)=>b.vol-a.vol);
    const keep=new Set(indexed.slice(0,MAX_SPACES).map(x=>x.i));
    for(let i=0;i<alive.length;i++) if(alive[i]&&!keep.has(i)){alive[i]=false;aliveCount--;}
  }
  return spaces.filter((_,i)=>alive[i]);
}

function canStack(sp,ori,item,placed,cn){
  if(sp.y<=0) return true;
  if(!item.st) return false;
  for(const p of placed){
    if(!p.pos) continue;
    const pp=p.pos;
    if(Math.abs(pp.y+pp.h-sp.y)>1) continue;
    if(!p.st) continue;
    if(p.br>0 && item.wt>p.br) continue;
    if(sp.y+ori.h>cn.h) continue;
    if(sp.x>=pp.x && sp.z>=pp.z &&
       sp.x+ori.w<=pp.x+pp.w && sp.z+ori.d<=pp.z+pp.d) return true;
  }
  return false;
}

function checkConstraints(item,pos,cn,placed){
  if(item.nb && pos.y<=0) return false;
  if(item.fw){
    const onWall=(pos.x<=1)||(pos.z<=1)||(pos.x+pos.w>=cn.w-1)||(pos.z+pos.d>=cn.l-1);
    if(!onWall) return false;
  }
  return true;
}

// ===== 鑷€傚簲鏈€浼樻斁缃� =====
// 瀵规瘡涓┖闂达紝灏濊瘯鎵€鏈夋柟鍚戯紝閫夋氮璐规渶灏戠殑
function tryPlaceItem(item,spaces,placed,cn,totalWt){
  if(totalWt+item.wt>cn.mw) return null;
  const oris=getOrientations(item);

  // 绗竴姝ワ細鍙犳斁鍦ㄥ悓灏哄宸叉斁缃墿鍝佷笂
  if(item.st && stackMode && placed.length>0){
    let bestScore=1e18,bestPos=null;
    for(const p of placed){
      if(!p.st||!p.pos) continue;
      if(p.br>0&&item.wt>p.br) continue;
      const pAw=Math.max(p.l,p.w),pAd=Math.min(p.l,p.w);
      const iAw=Math.max(item.l,item.w),iAd=Math.min(item.l,item.w);
      if(pAw!==iAw||pAd!==iAd) continue;
      const topY=p.pos.y+p.pos.h;
      for(const ori of oris){
        if(ori.w<=p.pos.w&&ori.d<=p.pos.d){
          if(topY+ori.h>cn.h) continue;
          let blocked=false;
          for(const q of placed){
            if(!q.pos) continue;
            if(Math.abs(q.pos.y-topY)<1&&q.pos.x===p.pos.x&&q.pos.z===p.pos.z){blocked=true;break;}
          }
          if(blocked) continue;
          const testPos={x:p.pos.x,y:topY,z:p.pos.z,w:ori.w,h:ori.h,d:ori.d};
          if(!checkConstraints(item,testPos,cn,placed)) continue;
          // 璇勫垎锛氱┖闂存氮璐规渶灏�
          const wasted=(p.pos.w-ori.w)*(p.pos.d-ori.d)*ori.h;
          const score=topY*1e9+p.pos.z*1e5+p.pos.x*1e3+wasted;
          if(score<bestScore){bestScore=score;bestPos=testPos;}
        }
      }
    }
    if(bestPos){
      for(let si=0;si<spaces.length;si++){
        const sp=spaces[si];
        if(Math.abs(sp.x-bestPos.x)<1&&Math.abs(sp.y-bestPos.y)<1&&Math.abs(sp.z-bestPos.z)<1){
          const rem=sp.h-bestPos.h;
          if(rem>10) spaces[si]={x:sp.x,y:bestPos.y+bestPos.h,z:sp.z,w:sp.w,h:rem,d:sp.d};
          else spaces.splice(si,1);
          break;
        }
      }
      return{pos:bestPos,space:null};
    }
  }

  // 绗簩姝ワ細鑷€傚簲鏈€浼樻斁缃� 鈥斺€� 閬嶅巻鎵€鏈夌┖闂疵楁墍鏈夋柟鍚戯紝閫夋渶浼�
  let bestPos=null,bestScore=1e18,bestSpace=null;
  for(let si=0;si<spaces.length;si++){
    const sp=spaces[si];
    for(const ori of oris){
      if(ori.w>sp.w||ori.h>sp.h||ori.d>sp.d) continue;
      if(sp.y<=0&&sp.y+ori.h>cn.dh) continue;
      if(sp.y>0&&(!item.st||!stackMode)) continue;
      if(sp.y>0&&!canStack(sp,ori,item,placed,cn)) continue;
      const testPos={x:sp.x,y:sp.y,z:sp.z,w:ori.w,h:ori.h,d:ori.d};
      if(!checkConstraints(item,testPos,cn,placed)) continue;
      // 澶氱淮璇勫垎锛氬眰浼樺厛 + 鍓嶆柟浼樺厛 + 绌洪棿閫傞厤搴� + 绾︽潫濂栧姳
      let score=sp.y*1e9+sp.z*1e5+sp.x*1e3;
      // 绌洪棿閫傞厤搴︼細鐗╁搧灏哄瓒婃帴杩戠┖闂村昂瀵歌秺濂斤紙鍑忓皯纰庣墖锛�
      score+=(sp.w-ori.w)*100+(sp.d-ori.d)*100+(sp.h-ori.h)*50;
      // 闈犲濂栧姳
      if(item.fw&&(sp.x<=1||sp.z<=1||sp.x+ori.w>=cn.w-1||sp.z+ori.d>=cn.l-1)) score-=5e8;
      // 鐩搁偦濂栧姳
      if(item.ad&&placed.length>0){
        let minD=Infinity;
        for(const p of placed){
          if(!p.pos||p.n!==item.ad) continue;
          const d=Math.abs(sp.x+ori.w/2-p.pos.x-p.pos.w/2)+Math.abs(sp.z+ori.d/2-p.pos.z-p.pos.d/2);
          minD=Math.min(minD,d);
        }
        if(minD<Infinity) score-=Math.max(0,1e6-minD*10);
      }
      // 绋冲畾鎬�
      if(sp.y<=0) score-=(ori.w*ori.d)/(cn.w*cn.l)*1e4;
      if(score<bestScore){bestScore=score;bestPos=testPos;bestSpace=sp;}
    }
  }
  if(!bestPos) return null;
  return{pos:bestPos,space:bestSpace};
}

// ===== 鍗曟鎵撳寘妯℃嫙 =====
function simulatePack(items,cn){
  let placed=[],totalWt=0;
  let spaces=[{x:0,y:0,z:0,w:cn.w,h:cn.h,d:cn.l}];
  let unplaced=[];
  for(const item of items){
    const r=tryPlaceItem(item,spaces,placed,cn,totalWt);
    if(r){
      placed.push({...item,pos:r.pos});
      totalWt+=item.wt;
      if(r.space){
        const ns=splitSpace(r.space,r.pos);
        const idx=spaces.indexOf(r.space);
        if(idx>=0) spaces.splice(idx,1,...ns);
      }
      if(placed.length%10===0) spaces=pruneSpaces(spaces);
    } else { unplaced.push(item); }
  }
  spaces=pruneSpaces(spaces);
  // 濉紳杞�
  if(unplaced.length>0){
    unplaced.sort((a,b)=>a.l*a.w*a.h-b.l*b.w*b.h);
    const still=[];
    for(const item of unplaced){
      const r=tryPlaceItem(item,spaces,placed,cn,totalWt);
      if(r){
        placed.push({...item,pos:r.pos});
        totalWt+=item.wt;
        if(r.space){
          const ns=splitSpace(r.space,r.pos);
          const idx=spaces.indexOf(r.space);
          if(idx>=0) spaces.splice(idx,1,...ns);
        }
        if(placed.length%10===0) spaces=pruneSpaces(spaces);
      } else { still.push(item); }
    }
    unplaced=still;
  }
  const volU=placed.reduce((s,p)=>s+p.pos.w*p.pos.h*p.pos.d,0);
  return{placed,totalWt,unplaced,volU};
}

/* ===== MAIN CALCULATION ===== */
function doCalc(){
  try {
  clearLogs();
  if(!validateInputs()) return;
  if(!cargoList.length){toast('璇峰厛娣诲姞璐х墿','error');return;}
  
  const calcBtn=$('calcBtn');
  calcBtn.textContent='鈴� 鏅鸿兘璁＄畻涓�...';calcBtn.disabled=true;
  
  cargoListOrig=[...cargoList.map(g=>({...g}))];

  const cn=getCn();
  const volC=cn.l*cn.w*cn.h;
  log(`璐ф煖: ${cn.l}脳${cn.w}脳${cn.h}mm, 杞介噸${cn.mw}kg`);

  let items=[];
  cargoList.forEach(g=>{for(let i=0;i<g.q;i++) items.push({...g,uid:g.id+'_'+i});});
  log(`璐х墿鎬绘暟: ${items.length}浠禶);

  // ===== 澶氱瓥鐣ユ悳绱� + 灞€閮ㄤ紭鍖� =====
  function constraintSort(a,b){
    if(a.fw!==b.fw) return a.fw?-1:1;
    if(a.nb!==b.nb) return a.nb?1:-1;
    if(a.st!==b.st) return a.st?1:-1;
    const va=a.l*a.w*a.h, vb=b.l*b.w*b.h;
    if(vb!==va) return vb-va;
    const aw=Math.max(a.l,a.w),ad=Math.min(a.l,a.w);
    const bw=Math.max(b.l,b.w),bd=Math.min(b.l,b.w);
    return (bw*10000+bd)-(aw*10000+ad) || b.h-a.h;
  }

  const strategies=[
    {name:'绾︽潫浼樺厛',fn:constraintSort},
    {name:'浣撶Н闄嶅簭',fn:(a,b)=>b.l*b.w*b.h-a.l*a.w*a.h},
    {name:'浣撶Н鍗囧簭',fn:(a,b)=>a.l*a.w*a.h-b.l*b.w*b.h},
    {name:'楂樺害闄嶅簭',fn:(a,b)=>b.h-a.h||b.l*b.w*b.h-a.l*a.w*a.h},
    {name:'搴曢潰褰掔粍',fn:(a,b)=>{
      const aw=Math.max(a.l,a.w),ad=Math.min(a.l,a.w);
      const bw=Math.max(b.l,b.w),bd=Math.min(b.l,b.w);
      return(bw*10000+bd)-(aw*10000+ad)||b.h-a.h;
    }},
    {name:'瀹介潰浼樺厛',fn:(a,b)=>b.l*b.w-a.l*a.w||b.h-a.h},
    {name:'浜ゆ浛澶у皬',fn:(a,b)=>b.l*b.w*b.h-a.l*a.w*a.h},
  ];

  // 绗竴闃舵锛氬绛栫暐鏋勫缓
  let best=null;
  for(const s of strategies){
    const sorted=[...items].sort(s.fn);
    const r=simulatePack(sorted,cn);
    log(`[${s.name}] 瑁�${r.placed.length}浠� 鏈${r.unplaced.length}浠� 鍒╃敤${(r.volU/volC*100).toFixed(1)}%`);
    if(!best||r.placed.length>best.placed.length||(r.placed.length===best.placed.length&&r.volU>best.volU)){
      best={...r,strategy:s.name};
    }
    if(r.unplaced.length===0) break;
  }
  log(`鏈€浼樼瓥鐣�: ${best.strategy}, 瑁呰浇${best.placed.length}浠禶);

  // 绗簩闃舵锛氬眬閮ㄤ紭鍖栵紙瀵规渶浼樼粨鏋滃皾璇曟敼杩涳級
  if(best.unplaced.length>0&&best.placed.length>0){
    // 灏濊瘯锛氭妸鏈€鍚庢斁缃殑鍑犱釜鐗╁搧绉昏蛋锛岀敤涓嶅悓椤哄簭閲嶆帓
    const placed=best.placed;
    const unplaced=best.unplaced;
    // 灏濊瘯鎶婂凡鏀剧疆鐨勫ぇ浠剁Щ璧帮紝鎹㈠叆鏈斁缃殑灏忎欢
    for(let swapCount=1;swapCount<=Math.min(5,placed.length);swapCount++){
      const moved=placed.splice(placed.length-swapCount,swapCount);
      const freedWt=moved.reduce((s,m)=>s+m.wt,0);
      const freedVol=moved.reduce((s,m)=>s+m.pos.w*m.pos.h*m.pos.d,0);
      // 鐢ㄩ噴鏀剧殑绌洪棿灏濊瘯鏀剧疆鏈杞界殑鐗╁搧
      const extraItems=[...unplaced,...moved.map(m=>{const{pos,...rest}=m;return rest;})];
      extraItems.sort((a,b)=>a.l*a.w*a.h-b.l*b.w*b.h);
      const freedSpaces=[{x:0,y:0,z:0,w:cn.w,h:cn.h,d:cn.l}];
      // 鐢ㄥ綋鍓嶅凡鏀剧疆鐗╁搧鏋勫缓绌洪棿
      let tempPlaced=[];
      let tempWt=0;
      for(const p of placed){
        tempPlaced.push(p);
        tempWt+=p.wt;
      }
      // 绠€鍗曢噸璇�
      const newItems=[...placed.map(p=>{const{pos,...rest}=p;return rest;}),...unplaced];
      newItems.sort(constraintSort);
      const r2=simulatePack(newItems,cn);
      if(r2.placed.length>best.placed.length||(r2.placed.length===best.placed.length&&r2.volU>best.volU)){
        log(`灞€閮ㄤ紭鍖�(閲嶆帓${swapCount}浠�): 瑁呰浇${r2.placed.length}浠� 鈫慲);
        best={...r2,strategy:best.strategy+'+浼樺寲'};
      }
      // 鎭㈠
      placed.push(...moved);
    }
  }

  let placed=best.placed;
  let totalWt=best.totalWt;
  let unplacedList=best.unplaced;

  volU=placed.reduce((s,p)=>s+p.pos.w*p.pos.h*p.pos.d,0);
  const unplaced=unplacedList.length;
  const vu=(volU/volC*100).toFixed(1);
  const wu=(totalWt/cn.mw*100).toFixed(1);
  log(`鏈€缁�: 瑁呰浇${placed.length}浠�, 鏈${unplaced}浠�, 浣撶Н${vu}%, 閲嶉噺${wu}%`);

  result={
    placed,unplaced,cn,
    stats:{
      ld:placed.length,ul:unplaced,tot:items.length,
      vu,wu,volU,totalWt,
      cnN:Math.ceil(items.length/Math.max(placed.length,1))
    }
  };

  // 鏇存柊璐х墿鍒楄〃锛氬噺鍘诲凡瑁呰浇鏁伴噺
  if(placed.length>0){
    const placedCounts={};
    placed.forEach(p=>{placedCounts[p.id]=(placedCounts[p.id]||0)+1;});
    cargoList=cargoList.map(g=>{
      const pc=placedCounts[g.id]||0;
      return pc<g.q?{...g,q:g.q-pc}:null;
    }).filter(Boolean);
    renderTB();
  }

  updateStats();buildRenderList();renderLayers();renderReport();
  animReset();$('animBar').style.display='flex';
  toast(`瑁呰浇瀹屾垚: ${placed.length}浠�, 鍒╃敤鐜�${vu}%`,'success');

  requestAnimationFrame(()=>{resizeCanvas();requestAnimationFrame(drawScene)});

  } catch(e) {
    console.error('doCalc error:', e);
    toast('璁＄畻鍑洪敊: ' + e.message, 'error', 5000);
  }
  // 鎭㈠鎸夐挳
  const calcBtn=$('calcBtn');
  calcBtn.textContent='鈻� 寮€濮嬭绠�';calcBtn.disabled=false;
}

