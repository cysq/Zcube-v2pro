      <div style="flex:1;border:1px solid #ddd;border-radius:6px;padding:8px;text-align:center;background:#f8f9fb">
        <div style="font-size:18px;font-weight:bold;color:#4a8eff">${s.vu}%</div><div style="font-size:8px;color:#888">浣撶Н鍒╃敤鐜�</div></div>
      <div style="flex:1;border:1px solid #ddd;border-radius:6px;padding:8px;text-align:center;background:#f8f9fb">
        <div style="font-size:18px;font-weight:bold;color:#4a8eff">${s.wu}%</div><div style="font-size:8px;color:#888">閲嶉噺鍒╃敤鐜�</div></div>
      <div style="flex:1;border:1px solid #ddd;border-radius:6px;padding:8px;text-align:center;background:#f8f9fb">
        <div style="font-size:18px;font-weight:bold;color:#4a8eff">${s.totalWt.toLocaleString()}</div><div style="font-size:8px;color:#888">瑁呰浇閲嶉噺(kg)</div></div>
    </div>`:'<p style="color:red">鏃犺绠楃粨鏋�</p>';

    const cargoRows=Object.entries(sm).map(([nm,d])=>
      `<tr><td>${nm}</td><td>${d.l}脳${d.w}脳${d.h}</td><td>${d.c}</td><td>${(d.wt/d.c).toFixed(1)}</td><td>${d.wt.toLocaleString()}</td><td>${(d.vol/1e9).toFixed(3)}</td></tr>`
    ).join('');

    const imgHtml=screenshots[idx]?`<div style="margin:6px 0"><img src="${screenshots[idx]}" style="width:100%;border:1px solid #ddd;border-radius:6px"></div>`:'';

    return `<div style="width:780px;padding:16px 20px;font-family:'Microsoft YaHei','SimHei','PingFang SC',sans-serif;color:#333;font-size:11px;line-height:1.5">
      <div style="display:flex;justify-content:space-between;align-items:baseline;border-bottom:2px solid #4a8eff;padding-bottom:6px;margin-bottom:6px">
        <div style="font-size:15px;font-weight:bold">${idx+1}. ${scheme.name}</div>
        <div style="font-size:9px;color:#999">${scheme.date}</div>
      </div>
      ${imgHtml}
      <div style="font-size:10px;color:#555;margin-bottom:4px">闆嗚绠�: ${cn.l}脳${cn.w}脳${cn.h}mm | 杞介噸: ${cn.mw.toLocaleString()}kg | 闄愰珮: ${cn.dh}mm</div>
      ${statsHTML}
      <div style="font-size:11px;font-weight:600;margin:6px 0 4px">璐х墿姹囨€�</div>
      <table style="width:100%;border-collapse:collapse;font-size:9px">
        <thead><tr style="background:#f0f4fa">
          <th style="border:1px solid #ddd;padding:4px 5px;text-align:left">鍚嶇О</th>
