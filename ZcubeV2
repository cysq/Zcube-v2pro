        </tr></thead>
        <tbody>${cargoRows}
        ${s?`<tr style="font-weight:bold;background:#f8f9fb"><td style="border:1px solid #ddd;padding:4px 5px">鍚堣</td><td style="border:1px solid #ddd;padding:4px 5px">鈥�</td><td style="border:1px solid #ddd;padding:4px 5px">${s.ld}</td><td style="border:1px solid #ddd;padding:4px 5px">鈥�</td><td style="border:1px solid #ddd;padding:4px 5px">${s.totalWt.toLocaleString()}</td><td style="border:1px solid #ddd;padding:4px 5px">${(s.volU/1e9).toFixed(3)}</td></tr>`:''}
        </tbody></table>
    </div>`;
  }

  try{
    const{jsPDF}=window.jspdf;
    const doc=new jsPDF('p','mm','a4');
    const PW=210,PH=297;

    for(let si=0;si<schemes.length;si++){
      if(si>0) doc.addPage();

      const container=document.createElement('div');
      container.style.cssText='position:fixed;left:-9999px;top:0;width:780px;z-index:-1;background:#fff';
      container.innerHTML=buildPageHTML(schemes[si],si);
      document.body.appendChild(container);

      const imgs=container.querySelectorAll('img');
      await Promise.all(Array.from(imgs).map(img=>new Promise(r=>{
        if(img.complete)r();else{img.onload=r;img.onerror=r;}
      })));

      const cvs=await html2canvas(container,{scale:2,useCORS:true,backgroundColor:'#fff',width:780,windowWidth:780});
      document.body.removeChild(container);

      const imgData=cvs.toDataURL('image/png');
      const imgW=PW-16;
      const imgH=cvs.height/cvs.width*imgW;

      if(imgH<=PH-16){
        doc.addImage(imgData,'PNG',8,8,imgW,imgH);
      }else{
        let srcY=0;
        const srcPageH=(PH-16)/imgW*cvs.width;
        let page=0;
        while(srcY<cvs.height){
