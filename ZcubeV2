<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ZCube</title>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg0:#0b0d14;--bg1:#12151f;--bg2:#1a1e2d;--bgH:#2e3452;--bd:#303654;--t1:#e6e8f0;--t2:#9aa0b8;--t3:#606782;--ac:#4a8eff;--ac2:#3a72e0;--ok:#34d399;--warn:#fbbf24;--err:#f87171;--r:8px;--rl:12px}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg0);color:var(--t1);overflow:hidden;height:100vh;width:100vw}
button{cursor:pointer;font-family:inherit}input,select,textarea{font-family:inherit}

/* ===== LAYOUT ===== */
.app{display:flex;flex-direction:column;height:100vh;width:100vw}
.topbar{flex:0 0 52px;background:var(--bg1);border-bottom:1px solid var(--bd);display:flex;align-items:center;padding:0 12px;gap:10px;z-index:100;flex-wrap:wrap}
.topbar h1{font-size:17px;font-weight:700;white-space:nowrap}.topbar h1 b{color:var(--ac)}
.topbar-actions{display:flex;gap:6px;margin-left:auto;flex-wrap:wrap}
.main-area{flex:1;display:flex;overflow:hidden;height:0}
.statsbar{flex:0 0 auto;min-height:44px;background:var(--bg1);border-top:1px solid var(--bd);display:flex;align-items:center;padding:8px 12px;gap:12px;font-size:12px;flex-wrap:wrap;justify-content:flex-start}
.statsbar .si{white-space:nowrap}

/* ===== SIDEBAR ===== */
.sidebar{flex:0 0 340px;min-width:280px;max-width:400px;background:var(--bg1);border-right:1px solid var(--bd);overflow-y:auto;overflow-x:hidden;padding:14px;display:flex;flex-direction:column;gap:12px;box-sizing:border-box}
.sidebar::-webkit-scrollbar{width:5px}.sidebar::-webkit-scrollbar-thumb{background:var(--bd);border-radius:3px}
.pnl{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r)}
.pnh{padding:10px 12px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:7px;cursor:pointer;user-select:none;background:var(--bg1);border-radius:var(--r)}.pnh:hover{background:var(--bgH)}
.pnh .ar{margin-left:auto;font-size:9px;color:var(--t3);transition:transform .2s}.pnh.shut .ar{transform:rotate(-90deg)}
.pnb{padding:10px 12px;display:flex;flex-direction:column;gap:8px;max-height:50vh;overflow-y:auto;overflow-x:hidden}.pnb.hid{display:none}
.pnb::-webkit-scrollbar{width:4px}.pnb::-webkit-scrollbar-thumb{background:var(--bd);border-radius:2px}
.fr{display:flex;flex-direction:column;gap:3px}.fr label{font-size:11px;color:var(--t2);font-weight:500;white-space:nowrap}
.fg3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:6px}
input[type="number"],input[type="text"],select,textarea{background:var(--bg0);border:1px solid var(--bd);color:var(--t1);padding:7px 9px;border-radius:6px;font-size:12px;outline:none;transition:border .2s;box-sizing:border-box;width:100%}
input:focus,select:focus,textarea:focus{border-color:var(--ac)}
input.invalid{border-color:var(--err);animation:shake .3s}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-3px)}75%{transform:translateX(3px)}}
.btn{padding:7px 14px;border-radius:6px;font-size:12px;font-weight:500;border:1px solid var(--bd);background:var(--bg2);color:var(--t1);transition:all .15s;display:inline-flex;align-items:center;gap:5px;box-sizing:border-box}
.btn:hover{background:var(--bgH);border-color:var(--t3)}
.btn:disabled{opacity:.4;cursor:not-allowed;pointer-events:none}
.bp{background:var(--ac);border-color:var(--ac);color:#fff}.bp:hover{background:var(--ac2)}
.bd{border-color:var(--err);color:var(--err)}.bd:hover{background:rgba(248,113,113,.1)}
.bs{padding:4px 9px;font-size:11px}.bb{width:100%;justify-content:center}
.bg{display:flex;gap:5px;flex-wrap:wrap}
.ctw{max-height:260px;overflow-y:auto;border:1px solid var(--bd);border-radius:6px}
.ct{width:100%;border-collapse:collapse;font-size:11px}
.ct th{background:var(--bg1);padding:6px 5px;text-align:left;font-weight:600;position:sticky;top:0;z-index:1;color:var(--t2);white-space:nowrap}
.ct td{padding:5px;border-top:1px solid var(--bd);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.ct tr:hover td{background:var(--bgH)}
.ct .ac{text-align:center}.db{background:none;border:none;color:var(--err);font-size:15px;padding:1px 5px;border-radius:4px}.db:hover{background:rgba(248,113,113,.15)}

/* ===== RIGHT CONTENT ===== */
.right-panel{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.vtabs{flex:0 0 auto;display:flex;flex-wrap:wrap;background:var(--bg1);border-bottom:1px solid var(--bd);padding:0 12px;gap:4px}
.vt{padding:9px 16px;font-size:12px;font-weight:500;color:var(--t3);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap}
.vt:hover{color:var(--t1)}.vt.on{color:var(--ac);border-bottom-color:var(--ac)}
.view-container{flex:1;position:relative;overflow:hidden}

/* ===== VIEW PANELS ===== */
.vp{position:absolute;top:0;left:0;right:0;bottom:0;display:none}
.vp.on{display:block}
#cv{display:block;width:100%;height:100%;background:#080a10}

/* ===== 3D CONTROLS ===== */
.vpres{position:absolute;top:10px;left:10px;display:flex;gap:5px;z-index:10;flex-wrap:wrap}
.vctrl{position:absolute;top:10px;right:10px;display:flex;flex-direction:column;gap:5px;z-index:10}
.vcb{width:34px;height:34px;border-radius:6px;background:var(--bg1);border:1px solid var(--bd);color:var(--t1);font-size:15px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;box-sizing:border-box}
.vcb:hover{background:var(--bgH)}
.vcb.on{background:var(--ac);border-color:var(--ac);color:#fff}
.ob{padding:5px 10px;border-radius:5px;font-size:11px;font-weight:500;border:1px solid var(--bd);background:var(--bg2);color:var(--t2);cursor:pointer;transition:all .15s;box-sizing:border-box}
.ob:hover{border-color:var(--ac);color:var(--t1)}
.ob.on{background:var(--ac);border-color:var(--ac);color:#fff}

/* Animation bar */
.acbar{position:absolute;bottom:14px;left:50%;transform:translateX(-50%);background:var(--bg1);border:1px solid var(--bd);border-radius:var(--rl);padding:8px 16px;display:none;align-items:center;gap:10px;z-index:10;box-shadow:0 8px 32px rgba(0,0,0,.5);flex-wrap:wrap;justify-content:center}
.abtn{width:30px;height:30px;border-radius:50%;background:var(--bg2);border:1px solid var(--bd);color:var(--t1);font-size:13px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;box-sizing:border-box}.abtn:hover,.abtn.on{background:var(--ac);border-color:var(--ac)}
.aprog{width:180px;max-width:100%;height:4px;background:var(--bg0);border-radius:2px;cursor:pointer;position:relative;box-sizing:border-box}
.apfill{height:100%;background:var(--ac);border-radius:2px;transition:width .08s linear}
.aspr{position:relative}.asbtn{padding:3px 8px;font-size:10px;background:var(--bg2);border:1px solid var(--bd);color:var(--t1);border-radius:4px;cursor:pointer;box-sizing:border-box}
.asmen{position:absolute;bottom:100%;left:0;background:var(--bg1);border:1px solid var(--bd);border-radius:6px;padding:3px;display:none;margin-bottom:4px;min-width:50px;z-index:11}
.asmen.sh{display:block}.aso{padding:3px 8px;font-size:10px;cursor:pointer;border-radius:4px;text-align:center}.aso:hover{background:var(--bgH)}.aso.on{color:var(--ac)}
.asinfo{font-size:11px;color:var(--t3);min-width:70px;text-align:center;white-space:nowrap}

/* Tooltip */
.ttp{position:absolute;background:var(--bg1);border:1px solid var(--bd);border-radius:var(--r);padding:8px 12px;font-size:11px;pointer-events:none;z-index:50;box-shadow:0 8px 32px rgba(0,0,0,.5);display:none;min-width:160px;max-width:300px;word-wrap:break-word}
.ttp .tn{font-weight:600;font-size:12px;margin-bottom:5px}.ttp .tr{display:flex;justify-content:space-between;gap:10px;padding:1px 0}.ttp .tl{color:var(--t3)}

/* Color legend */
.cleg{position:absolute;bottom:60px;right:10px;background:var(--bg1);border:1px solid var(--bd);border-radius:var(--r);padding:8px 10px;z-index:10;font-size:10px;display:none;max-height:200px;overflow-y:auto}
.cleg .cli{display:flex;align-items:center;gap:6px;padding:2px 0;white-space:nowrap}.cleg .csw{width:12px;height:12px;border-radius:3px;flex-shrink:0}

/* Layer view */
.lv{padding:16px;overflow-y:auto;height:100%}.ls{margin-bottom:16px}.lh{font-size:13px;font-weight:600;margin-bottom:8px;padding-bottom:5px;border-bottom:1px solid var(--bd)}
.lg{display:flex;flex-wrap:wrap;gap:5px}.li{background:var(--bg2);border:1px solid var(--bd);border-radius:6px;padding:6px 10px;font-size:11px;min-width:130px;box-sizing:border-box}
.li .ln{font-weight:600;margin-bottom:3px}.li .ld{color:var(--t3);font-size:10px}

/* Report */
.rv{padding:16px;overflow-y:auto;height:100%}.rs{margin-bottom:20px}.rs h3{font-size:14px;font-weight:600;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--bd)}
.rg{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.rdc{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r);padding:12px;box-sizing:border-box}
.rdl{font-size:11px;color:var(--t3);margin-bottom:3px}.rdv{font-size:18px;font-weight:700}
.rb{height:6px;background:var(--bg0);border-radius:3px;overflow:hidden;margin-top:6px}.rbf{height:100%;border-radius:3px}
.rsg{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r);padding:12px;box-sizing:border-box}
.rsg li{font-size:12px;padding:3px 0;color:var(--t2);list-style:none}.rsg li::before{content:'馃挕 '}
.rpt{width:100%;border-collapse:collapse;font-size:11px}.rpt th{background:var(--bg1);padding:7px;text-align:left;font-weight:600;color:var(--t2);white-space:nowrap}.rpt td{padding:7px;border-top:1px solid var(--bd);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* Toast */
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(100px);background:var(--bg1);border:1px solid var(--bd);border-radius:var(--r);padding:10px 20px;font-size:12px;z-index:2000;box-shadow:0 8px 32px rgba(0,0,0,.5);transition:transform .3s ease;white-space:nowrap}
.toast.show{transform:translateX(-50%) translateY(0)}
.toast.success{border-color:var(--ok);color:var(--ok)}
.toast.error{border-color:var(--err);color:var(--err)}
.toast.info{border-color:var(--ac);color:var(--ac)}

/* Keyboard hint */
.kbd{display:inline-block;background:var(--bg0);border:1px solid var(--bd);border-radius:3px;padding:1px 5px;font-size:10px;font-family:monospace;color:var(--t3);margin-left:4px;vertical-align:middle}

/* Modal */
.mo{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1000;display:none;align-items:center;justify-content:center;overflow-y:auto}
.mo.sh{display:flex}
.md{background:var(--bg1);border:1px solid var(--bd);border-radius:var(--rl);width:90%;max-width:560px;max-height:80vh;display:flex;flex-direction:column;box-shadow:0 16px 64px rgba(0,0,0,.5);box-sizing:border-box}
.mh{padding:14px 18px;border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between;box-sizing:border-box}.mh h2{font-size:15px;white-space:nowrap}
.mc{background:none;border:none;color:var(--t3);font-size:18px;cursor:pointer}.mc:hover{color:var(--t1)}
.mb{padding:16px 18px;overflow-y:auto;flex:1;box-sizing:border-box}.mf{padding:10px 18px;border-top:1px solid var(--bd);display:flex;justify-content:flex-end;gap:6px;flex-wrap:wrap;box-sizing:border-box}
.plt{width:100%;border-collapse:collapse;font-size:12px}.plt th{background:var(--bg0);padding:8px 6px;text-align:left;font-weight:600;color:var(--t2);position:sticky;top:0;white-space:nowrap}.plt td{padding:6px;border-top:1px solid var(--bd);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.plt tr:hover td{background:var(--bgH)}.ps{width:100%;margin-bottom:10px;box-sizing:border-box}
.csa{width:100%;min-height:100px;font-family:monospace;font-size:11px;box-sizing:border-box}
.csf{font-size:11px;color:var(--t3);margin-top:6px;padding:8px;background:var(--bg0);border-radius:6px;box-sizing:border-box}
/* ===== RESPONSIVE DESIGN ===== */
@media (max-width: 1024px) {
  .sidebar{flex:0 0 300px;min-width:260px}
  .vtabs{padding:0 8px}
  .vt{padding:8px 12px}
  .statsbar{gap:10px;padding:8px 8px}
  .topbar{padding:0 8px}
}

@media (max-width: 768px) {
  .main-area{flex-direction:column}
  .sidebar{flex:0 0 auto;max-height:50vh;border-right:none;border-bottom:1px solid var(--bd);overflow-y:auto}
  .right-panel{flex:1}
  .vtabs{padding:0 6px}
  .vt{padding:7px 10px;font-size:11px}
  .statsbar{gap:8px;padding:6px 6px;font-size:11px}
  .topbar{padding:0 6px;gap:8px}
  .topbar h1{font-size:15px}
  .topbar-actions .btn{padding:6px 12px;font-size:11px}
  .pnb{padding:8px 10px}
  .fg3{grid-template-columns:1fr 1fr;gap:5px}
  .fg2{gap:5px}
  .ctw{max-height:150px}
  .acbar{padding:6px 12px;gap:8px}
  .aprog{width:140px}
  .md{width:95%;max-width:480px}
  .mh{padding:12px 16px}
  .mb{padding:14px 16px}
  .mf{padding:8px 16px}
}

@media (max-width: 480px) {
  .sidebar{min-width:240px}
  .topbar{flex-direction:column;align-items:flex-start;min-height:60px;padding:8px 6px}
  .topbar-actions{margin-left:0;width:100%;justify-content:flex-end}
  .statsbar{flex-direction:column;align-items:flex-start;min-height:60px;gap:4px}
  .vtabs{flex-direction:column;align-items:flex-start;padding:4px 6px}
  .vt{padding:6px 8px;width:100%;text-align:left}
  .fg3{grid-template-columns:1fr;gap:4px}
  .fg2{grid-template-columns:1fr;gap:4px}
  .bg{flex-direction:column}
  .bg .btn{width:100%}
  .acbar{flex-direction:column;gap:6px}
  .aprog{width:100%}
  .md{width:98%;max-width:320px}
  .mh h2{font-size:14px}
  .rb{display:none}
}

@media (max-height: 600px) {
  .sidebar{max-height:250px}
  .ctw{max-height:120px}
  .acbar{bottom:8px;padding:6px 12px}
  .cleg{bottom:40px}
}

/* ===== PRINT STYLES ===== */
@media print {
  body{background:white;color:black;overflow:visible;height:auto;width:auto}
  .app{height:auto;width:auto}
  .topbar,.sidebar,.statsbar,.vtabs,.vpres,.vctrl,.acbar,.cleg,.ttp,.mo,.toast{display:none}
  .right-panel{flex:1}
  .vp{position:static;display:block}
  #cv{display:none}
  #panelRp{display:block}
  .rv{padding:20px}
}

</style>
</head>
