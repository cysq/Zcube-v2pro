// 鍏夋簮閰嶇疆 鈥� 涓夌偣鐓ф槑绯荤粺
const LIGHT_KEY  = [0.35, 0.75, 0.55];  // 涓诲厜锛堟殩鐧斤級
const LIGHT_FILL = [-0.4, 0.35, -0.3];  // 琛ュ厜锛堝喎鑹诧紝寮憋級
const LIGHT_BACK = [-0.2, 0.5, -0.7];   // 杞粨鍏夛紙鑳岄潰锛�
const AMBIENT    = 0.18;                 // 鐜鍏夊己搴�
const SPEC_POWER = 24;                   // 楂樺厜鎸囨暟
const SPEC_INTENSITY = 0.25;             // 楂樺厜寮哄害

// 鐩告満骞虫粦杩囨浮鐘舵€�
let camTarget = null; // { rotX, rotY, zoom, t0, dur }
let camSource = null;

function init3D(){
  canvas=$('cv');
  const ro=new ResizeObserver(()=>{resizeCanvas();requestRedraw()});
  ro.observe(canvas.parentElement);
  resizeCanvas();
  initStackMode();

  // Mouse interaction 鈥� 宸﹂敭鏃嬭浆, 涓敭骞崇Щ, 婊氳疆缂╂斁
  canvas.addEventListener('mousedown',e=>{
    if(e.button===1){
      // 涓敭骞崇Щ
      e.preventDefault();
      isPan=true;panStartX=e.clientX;panStartY=e.clientY;
      canvas.style.cursor='move';
    }else if(e.button===0){
      // 宸﹂敭鏃嬭浆
      isDrag=true;dragStartX=e.clientX;dragStartY=e.clientY;
      canvas.style.cursor='grabbing';
    }
  });
  window.addEventListener('mouseup',e=>{
    if(e.button===1){isPan=false;canvas.style.cursor='default';}
    if(e.button===0){isDrag=false;canvas.style.cursor='default';}
  });
  canvas.addEventListener('mousemove',e=>{
    if(isPan){
      const dx=e.clientX-panStartX;
      const dy=e.clientY-panStartY;
      panX+=dx*5/zoom;
      panZ+=dy*5/zoom;
      panStartX=e.clientX;panStartY=e.clientY;
      camTarget=null;
    }
    if(isDrag){
      rotY+=(e.clientX-dragStartX)*0.008;
      rotX+=(e.clientY-dragStartY)*0.008;
      rotX=Math.max(-1.5,Math.min(1.5,rotX));
      dragStartX=e.clientX;dragStartY=e.clientY;
      camTarget=null;
    }
    checkHover(e);requestRedraw();
  });
  // Touch support for mobile
  let touchStartX=0,touchStartY=0;
  canvas.addEventListener('touchstart',e=>{
    if(e.touches.length===1){
      const t=e.touches[0];touchStartX=t.clientX;touchStartY=t.clientY;
      e.preventDefault();
    }
  },{passive:false});
  canvas.addEventListener('touchmove',e=>{
    if(e.touches.length===1){
      const t=e.touches[0];
      rotY+=(t.clientX-touchStartX)*0.008;
      rotX+=(t.clientY-touchStartY)*0.008;
      rotX=Math.max(-1.5,Math.min(1.5,rotX));
      touchStartX=t.clientX;touchStartY=t.clientY;
      camTarget=null;
      requestRedraw();e.preventDefault();
    }
  },{passive:false});

  canvas.addEventListener('wheel',e=>{e.preventDefault();zoom*=e.deltaY>0?1.08:0.92;zoom=Math.max(0.15,Math.min(6,zoom));camTarget=null;requestRedraw()},{passive:false});
  canvas.addEventListener('mouseleave',()=>{hoverIdx=-1;$('tooltip').style.display='none';requestRedraw()});

  drawScene();
}

// requestAnimationFrame 鑺傛祦閲嶇粯
function requestRedraw(){
  if(!needRedraw){needRedraw=true;requestAnimationFrame(()=>{needRedraw=false;drawScene();});}
}

function resizeCanvas(){
  const box=canvas.parentElement;
  const rect=box.getBoundingClientRect();
  if(rect.width<10||rect.height<10) return;
  const dpr=window.devicePixelRatio||1;
  canvas.width=Math.round(rect.width*dpr);
  canvas.height=Math.round(rect.height*dpr);
  canvas.style.width=rect.width+'px';
  canvas.style.height=rect.height+'px';
  W=canvas.width;H=canvas.height;
}

function buildRenderList(){
  colorMap={};let ci=0;
  renderList=result.placed.map(p=>{
    if(!(p.n in colorMap)) colorMap[p.n]=PALETTE[ci++%PALETTE.length];
    return{pos:p.pos,color:colorMap[p.n],name:p.n,wt:p.wt};
  });
  const leg=$('colorLeg');
  if(renderList.length){
    leg.style.display='block';
    leg.innerHTML=Object.entries(colorMap).map(([n,c])=>`<div class="cli"><div class="csw" style="background:rgb(${c[0]},${c[1]},${c[2]})"></div><span>${esc(n)}</span></div>`).join('');
  } else leg.style.display='none';
}

// 褰掍竴鍖栧厜婧愬悜閲�
function normalize3(v){const l=Math.sqrt(v[0]*v[0]+v[1]*v[1]+v[2]*v[2]);return l>0?[v[0]/l,v[1]/l,v[2]/l]:[0,1,0]}
const L_KEY=normalize3(LIGHT_KEY), L_FILL=normalize3(LIGHT_FILL), L_BACK=normalize3(LIGHT_BACK);

// 3D鎶曞奖 鈥� 缂撳瓨cos/sin閬垮厤閲嶅璁＄畻
function proj(x,y,z){
  const cn=result?result.cn:getCn();
  x-=cn.w/2;z-=cn.l/2;
  x+=panX;z+=panZ; // 骞崇Щ鍋忕Щ
  const cosR=Math.cos(rotY),sinR=Math.sin(rotY);
  const cosP=Math.cos(rotX),sinP=Math.sin(rotX);
  const rx2=x*cosR-z*sinR,rz2=x*sinR+z*cosR;
  const ry2=y*cosP-rz2*sinP,rz3=y*sinP+rz2*cosP;
  const scale=zoom*Math.min(W,H)/3000;
  return[W/2+rx2*scale,H/2-ry2*scale,rz3];
}

// ===== 宸ヤ笟杞欢鏍囧噯 3D 鍧愭爣杞存帶浠� =====
function drawCoordinateAxes(){
  const RADIUS = 52, TIP_LEN = 10, TIP_W = 4;
  const CX = 65, CY = H-65;
  const cosR=Math.cos(rotY), sinR=Math.sin(rotY);
  const cosP=Math.cos(rotX), sinP=Math.sin(rotX);

  ctx.save();
  ctx.globalAlpha = 0.35;
  ctx.fillStyle = '#0b0d14';
  ctx.beginPath(); ctx.arc(CX,CY,30,0,Math.PI*2); ctx.fill();
  ctx.globalAlpha = 0.15;
  ctx.strokeStyle = '#303654'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.arc(CX,CY,30,0,Math.PI*2); ctx.stroke();
  ctx.globalAlpha = 1.0;

  // 鍙傝€冨渾鐜�
  ctx.globalAlpha = 0.12;
  ctx.strokeStyle = '#606782'; ctx.lineWidth = 0.8;
  const ringR = 22;
  ctx.beginPath();
  for(let a=0; a<=Math.PI*2; a+=0.05){
    const rx = ringR*Math.cos(a), rz = ringR*Math.sin(a);
    const px = rx*cosR - rz*sinR;
    const py = -(rx*sinR + rz*cosR)*sinP*0.5;
    if(a===0) ctx.moveTo(CX+px, CY+py);
    else ctx.lineTo(CX+px, CY+py);
  }
  ctx.closePath(); ctx.stroke();
  ctx.globalAlpha = 1.0;
  ctx.restore();

  const axes = [
    { endX:CX+RADIUS*cosR, endY:CY-RADIUS*sinR*sinP*0.6, col:'#f87171', label:'X' },
    { endX:CX, endY:CY-RADIUS*cosP, col:'#34d399', label:'Y' },
    { endX:CX+RADIUS*sinR, endY:CY+RADIUS*cosR*sinP*0.6, col:'#4a8eff', label:'Z' }
  ];
  const depthOrder = axes.map((a,i)=>({i,d:a.endY})).sort((a,b)=>a.d-b.d);

  depthOrder.forEach(({i})=>{
    const a = axes[i];
    const dx = a.endX-CX, dy = a.endY-CY;
    const len = Math.sqrt(dx*dx+dy*dy)||1;
    const nx = dx/len, ny = dy/len;

    ctx.save();ctx.shadowColor=a.col;ctx.shadowBlur=6;
    ctx.strokeStyle=a.col;ctx.lineWidth=2.5;ctx.lineCap='round';
    ctx.beginPath();ctx.moveTo(CX,CY);ctx.lineTo(a.endX,a.endY);ctx.stroke();ctx.restore();

    ctx.strokeStyle=a.col;ctx.lineWidth=2.2;ctx.lineCap='round';
    ctx.beginPath();ctx.moveTo(CX,CY);ctx.lineTo(a.endX,a.endY);ctx.stroke();

    const tipBaseX=a.endX-nx*TIP_LEN, tipBaseY=a.endY-ny*TIP_LEN;
    const perpX=-ny, perpY=nx;
    ctx.fillStyle=a.col;ctx.beginPath();
    ctx.moveTo(a.endX,a.endY);
    ctx.lineTo(tipBaseX+perpX*TIP_W,tipBaseY+perpY*TIP_W);
    ctx.lineTo(tipBaseX-perpX*TIP_W,tipBaseY-perpY*TIP_W);
    ctx.closePath();ctx.fill();

    const lx=a.endX+nx*16, ly=a.endY+ny*16;
    ctx.font='bold 11px -apple-system,"Segoe UI",sans-serif';
    ctx.textAlign='center';ctx.textBaseline='middle';
    const tw=ctx.measureText(a.label).width;
    ctx.fillStyle=a.col;ctx.globalAlpha=0.9;
    roundRect(ctx,lx-tw/2-3,ly-8,tw+6,16,3);ctx.fill();
    ctx.globalAlpha=1;ctx.fillStyle='#fff';ctx.fillText(a.label,lx,ly+1);
  });
}

function roundRect(ctx,x,y,w,h,r){
  ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);
  ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);
  ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();
}

// ===== 鐩告満骞虫粦杩囨浮 =====
function smoothTransition(){
  if(!camTarget) return;
  const elapsed = performance.now() - camTarget.t0;
  let t = Math.min(1, elapsed / camTarget.dur);
  // easeInOutCubic
  t = t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2,3)/2;
  rotX = camSource.rotX + (camTarget.rotX - camSource.rotX) * t;
  rotY = camSource.rotY + (camTarget.rotY - camSource.rotY) * t;
  zoom = camSource.zoom + (camTarget.zoom - camSource.zoom) * t;
  if(t >= 1) camTarget = null;
  requestRedraw();
}

function drawScene(){
  if(!canvas)return;
  // 鐩告満杩囨浮
  smoothTransition();
  ctx=canvas.getContext('2d');

  // 鑳屾櫙娓愬彉
  const bg=ctx.createLinearGradient(0,0,0,H);
  bg.addColorStop(0,'#0d1018');bg.addColorStop(1,'#070910');
  ctx.fillStyle=bg;ctx.fillRect(0,0,W,H);

  drawCoordinateAxes();

  const cn=result?result.cn:getCn();
  const oX=0,oZ=0;

  // ===== 鍦伴潰缃戞牸 鈥� 甯︽笎鍙樻贰鍑� =====
  const gs=1000;
  ctx.lineWidth=0.6;
  for(let gx=0;gx<=cn.w;gx+=gs){
    const a=proj(oX+gx,0,oZ),b=proj(oX+gx,0,oZ+cn.l);
    const dist=Math.abs(gx-cn.w/2)/(cn.w/2);
    ctx.strokeStyle=`rgba(60,75,120,${0.2*(1-dist*0.5)})`;
    ctx.beginPath();ctx.moveTo(a[0],a[1]);ctx.lineTo(b[0],b[1]);ctx.stroke();
  }
  for(let gz=0;gz<=cn.l;gz+=gs){
    const a=proj(oX,0,oZ+gz),b=proj(oX+cn.w,0,oZ+gz);
    const dist=Math.abs(gz-cn.l/2)/(cn.l/2);
    ctx.strokeStyle=`rgba(60,75,120,${0.2*(1-dist*0.5)})`;
    ctx.beginPath();ctx.moveTo(a[0],a[1]);ctx.lineTo(b[0],b[1]);ctx.stroke();
  }

  // ===== 瀹瑰櫒 鈥� 鍗婇€忔槑澧� + 鍦版澘 =====
  drawWireframe(oX,0,oZ,cn.w,cn.h,cn.l,'rgba(60,75,110,0.5)',1.5);
  // 鍦版澘锛堝崐閫忔槑娣辫壊锛�
  drawQuad([oX,0,oZ],[oX+cn.w,0,oZ],[oX+cn.w,0,oZ+cn.l],[oX,0,oZ+cn.l],'rgba(12,16,28,0.35)');
  // 鍚庡锛堟瀬娣★級
  drawQuad([oX,0,oZ+cn.l],[oX+cn.w,0,oZ+cn.l],[oX+cn.w,cn.h,oZ+cn.l],[oX,cn.h,oZ+cn.l],'rgba(30,35,55,0.06)');
  // 鍙冲锛堟瀬娣★級
  drawQuad([oX+cn.w,0,oZ],[oX+cn.w,0,oZ+cn.l],[oX+cn.w,cn.h,oZ+cn.l],[oX+cn.w,cn.h,oZ],'rgba(30,35,55,0.04)');

  // 绌虹姸鎬佹彁绀�
  if(!result&&cargoList.length===0){
    ctx.fillStyle='#3a3f55';ctx.font=Math.round(W/50)+'px sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText('鐐瑰嚮銆屽紑濮嬭绠椼€嶆煡鐪�3D瑁呮煖鏁堟灉',W/2,H/2);
    ctx.font=Math.round(W/70)+'px sans-serif';ctx.fillStyle='#282c3d';
    ctx.fillText('鍏堝湪宸︿晶娣诲姞璐х墿锛岀劧鍚庣偣鍑昏绠�',W/2,H/2+40);
    return;
  }

  const total=renderList.length;
  let showN=animState.progress>0?Math.ceil(animState.progress*total):total;

  // ===== 鍦伴潰闃村奖灞� 鈥� 鍏堢敾闃村奖鍐嶇敾绠卞瓙 =====
  if(!wireframe){
    for(let i=0;i<showN&&i<total;i++){
      const item=renderList[i],p=item.pos;
      const sx=oX+p.x, sz=oZ+p.z;
      const shadowY=1; // 鐣ラ珮浜庡湴闈�
      const shadowPad=30; // 闃村奖澶栨墿
      // 鍗婇€忔槑榛戣壊妞渾鎶曞奖
      drawQuad(
        [sx-shadowPad,shadowY,sz-shadowPad],
        [sx+p.w+shadowPad,shadowY,sz-shadowPad],
        [sx+p.w+shadowPad,shadowY,sz+p.d+shadowPad],
        [sx-shadowPad,shadowY,sz+p.d+shadowPad],
        'rgba(0,0,0,0.12)'
      );
    }
  }

  // 鏋勫缓缁樺埗鍒楄〃锛堟繁搴︽帓搴忥級
  let drawItems=[];
  for(let i=0;i<showN&&i<total;i++){
    const item=renderList[i],p=item.pos;
    const pr=proj(oX+p.x+p.w/2,p.y+p.h/2,oZ+p.z+p.d/2);
    let slide=0;
    if(animState.progress>0&&i===showN-1){
      const frac=(animState.progress*total)-Math.floor(animState.progress*total);
      slide=(1-frac)*cn.w*1.5;
    }
    drawItems.push({item,depth:pr[2],slide,idx:i});
  }
  drawItems.sort((a,b)=>b.depth-a.depth);

  if(wireframe){
    ctx.lineWidth=1.5;
    drawItems.forEach(({item,slide})=>{
      const p=item.pos;
      drawWireframe(oX+p.x+slide,p.y,oZ+p.z,p.w,p.h,p.d,`rgb(${item.color})`);
    });
  } else {
    drawItems.forEach(({item,slide,idx})=>{
      const p=item.pos;
      drawBox(oX+p.x+slide,p.y,oZ+p.z,p.w,p.h,p.d,item.color,idx===hoverIdx);
    });
  }

  // ===== 灏哄鏍囨敞 鈥� 鍦ㄧ瀛愪笂鏂规樉绀哄悕绉� =====
  if(!wireframe && showN > 0 && showN <= 60){ // 鏁伴噺灏戞椂鎵嶆樉绀烘爣娉紝閬垮厤澶贡
    ctx.textAlign='center';ctx.textBaseline='bottom';
    drawItems.forEach(({item})=>{
      const p=item.pos;
      const top=proj(oX+p.x+p.w/2, p.y+p.h+30, oZ+p.z+p.d/2);
      const fontSize=Math.max(9, Math.min(12, 10*zoom));
      ctx.font=`600 ${fontSize}px -apple-system,sans-serif`;
      ctx.fillStyle='rgba(200,210,230,0.75)';
      ctx.fillText(item.name, top[0], top[1]);
    });
  }
}

function drawQuad(a,b,c,d,color){
  const pa=proj(a[0],a[1],a[2]),pb=proj(b[0],b[1],b[2]),pc=proj(c[0],c[1],c[2]),pd=proj(d[0],d[1],d[2]);
  ctx.fillStyle=color;ctx.beginPath();
  ctx.moveTo(pa[0],pa[1]);ctx.lineTo(pb[0],pb[1]);ctx.lineTo(pc[0],pc[1]);ctx.lineTo(pd[0],pd[1]);
  ctx.closePath();ctx.fill();
}

function drawWireframe(x,y,z,w,h,d,color,lw){
  const c=[[x,y,z],[x+w,y,z],[x+w,y,z+d],[x,y,z+d],[x,y+h,z],[x+w,y+h,z],[x+w,y+h,z+d],[x,y+h,z+d]];
  const p=c.map(v=>proj(...v));
  const edges=[[0,1],[1,2],[2,3],[3,0],[4,5],[5,6],[6,7],[7,4],[0,4],[1,5],[2,6],[3,7]];
  ctx.strokeStyle=color;ctx.lineWidth=lw||1;
  edges.forEach(([a,b])=>{ctx.beginPath();ctx.moveTo(p[a][0],p[a][1]);ctx.lineTo(p[b][0],p[b][1]);ctx.stroke()});
}

function drawBox(x,y,z,w,h,d,rgb,isHover){
  const corners=[[x,y,z],[x+w,y,z],[x+w,y,z+d],[x,y,z+d],[x,y+h,z],[x+w,y+h,z],[x+w,y+h,z+d],[x,y+h,z+d]];
  const pts=corners.map(c=>proj(...c));

  const faces=[
    {vi:[4,5,6,7],n:[0,1,0],name:'top'},
    {vi:[0,1,5,4],n:[0,0,-1],name:'front'},
    {vi:[1,2,6,5],n:[1,0,0],name:'right'},
    {vi:[3,0,4,7],n:[-1,0,0],name:'left'},
    {vi:[2,3,7,6],n:[0,0,1],name:'back'},
    {vi:[0,3,2,1],n:[0,-1,0],name:'bottom'}
  ];
  const r=rgb[0],g=rgb[1],b=rgb[2];

  const facesD=faces.map(f=>({...f,avgZ:f.vi.reduce((s,vi)=>s+pts[vi][2],0)/f.vi.length}));
  facesD.sort((a,b)=>b.avgZ-a.avgZ);

  const visibleEdges=[];

  facesD.forEach(f=>{
    // 娉曠嚎璁＄畻
    const v1=[corners[f.vi[1]][0]-corners[f.vi[0]][0],corners[f.vi[1]][1]-corners[f.vi[0]][1],corners[f.vi[1]][2]-corners[f.vi[0]][2]];
    const v2=[corners[f.vi[2]][0]-corners[f.vi[0]][0],corners[f.vi[2]][1]-corners[f.vi[0]][1],corners[f.vi[2]][2]-corners[f.vi[0]][2]];
    const fn=[v1[1]*v2[2]-v1[2]*v2[1],v1[2]*v2[0]-v1[0]*v2[2],v1[0]*v2[1]-v1[1]*v2[0]];
    const fLen=Math.sqrt(fn[0]*fn[0]+fn[1]*fn[1]+fn[2]*fn[2]);
    if(fLen<0.001)return;fn[0]/=fLen;fn[1]/=fLen;fn[2]/=fLen;

    // 灞忓箷绌洪棿鑳岄潰鍓旈櫎
    const p0=pts[f.vi[0]],p1=pts[f.vi[1]],p2=pts[f.vi[2]];
    const cross2d=(p1[0]-p0[0])*(p2[1]-p0[1])-(p1[1]-p0[1])*(p2[0]-p0[0]);
    if(cross2d>0)return;

    // ===== 澶氬厜婧愬厜鐓фā鍨� =====
    // 涓诲厜 鈥� 婕弽灏�
    const diffKey = Math.max(0, fn[0]*L_KEY[0]+fn[1]*L_KEY[1]+fn[2]*L_KEY[2]);
    // 琛ュ厜 鈥� 鍐疯壊寮卞厜
    const diffFill = Math.max(0, fn[0]*L_FILL[0]+fn[1]*L_FILL[1]+fn[2]*L_FILL[2]);
    // 杞粨鍏� 鈥� 鑳岄潰寰厜
    const diffBack = Math.max(0, fn[0]*L_BACK[0]+fn[1]*L_BACK[1]+fn[2]*L_BACK[2]);

    // 楂樺厜锛圔linn-Phong锛夆€� 鍗婅鍚戦噺
    const viewDir = [0, 0, 1]; // 绠€鍖栵細瑙傚療鏂瑰悜杩戜技
    const halfKey = normalize3([L_KEY[0]+viewDir[0], L_KEY[1]+viewDir[1], L_KEY[2]+viewDir[2]]);
    const specDot = Math.max(0, fn[0]*halfKey[0]+fn[1]*halfKey[1]+fn[2]*halfKey[2]);
    const specular = Math.pow(specDot, SPEC_POWER) * SPEC_INTENSITY;

    // 鏈€缁堜寒搴� = 鐜 + 婕弽灏� + 楂樺厜
    const brightness = AMBIENT + diffKey*0.50 + diffFill*0.12 + diffBack*0.08;
    // 楂樺厜鍋忕櫧鑹诧紙澧炲姞棰滆壊鐨勪寒搴﹂€氶亾锛�
    const cr=Math.min(255, Math.round(r*brightness + 255*specular));
    const cg=Math.min(255, Math.round(g*brightness + 255*specular));
    const cb=Math.min(255, Math.round(b*brightness + 255*specular));

    // 鐢ㄦ笎鍙樺～鍏呴潰锛堜粠浜埌鏆楁ā鎷熸洸闈㈡繁搴︽劅锛�
    // 鎵惧埌闈㈢殑灞忓箷杈圭晫
    const fv = f.vi.map(i => pts[i]);
    const minX = Math.min(...fv.map(p=>p[0]));
    const maxX = Math.max(...fv.map(p=>p[0]));
    const minY = Math.min(...fv.map(p=>p[1]));
    const maxY = Math.max(...fv.map(p=>p[1]));

    // 濡傛灉闈㈣冻澶熷ぇ锛岀敤娓愬彉锛涘惁鍒欑敤绾壊
    const faceArea = (maxX-minX) * (maxY-minY);
    if(faceArea > 500 && (maxX-minX) > 10 && (maxY-minY) > 10){
      // 寰勫悜娓愬彉 鈥� 浠庝腑蹇冧寒鍒拌竟缂樻殫
      const cx = (minX+maxX)/2, cy = (minY+maxY)/2;
      const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.max(maxX-minX, maxY-minY)*0.6);
      const br = Math.min(255, Math.round(r*(brightness+0.08)+255*specular));
      const bg2 = Math.min(255, Math.round(g*(brightness+0.08)+255*specular));
      const bb = Math.min(255, Math.round(b*(brightness+0.08)+255*specular));
      grad.addColorStop(0, `rgba(${br},${bg2},${bb},0.88)`);
      grad.addColorStop(1, `rgba(${cr},${cg},${cb},0.82)`);
      ctx.fillStyle = grad;
    } else {
      ctx.fillStyle=`rgba(${cr},${cg},${cb},0.85)`;
    }

    ctx.strokeStyle=`rgba(${cr},${cg},${cb},0.85)`;
    ctx.lineWidth=0.5;
    ctx.beginPath();
    f.vi.forEach((vi,j)=>{const pt=pts[vi];j===0?ctx.moveTo(pt[0],pt[1]):ctx.lineTo(pt[0],pt[1])});
    ctx.closePath();ctx.fill();ctx.stroke();

    // 鏀堕泦鍙闈㈣竟缂�
    const edges=[[f.vi[0],f.vi[1]],[f.vi[1],f.vi[2]],[f.vi[2],f.vi[3]],[f.vi[3],f.vi[0]]];
    edges.forEach(e=>visibleEdges.push(e));
  });

  // ===== 纭竟绾� =====
  const edgeR=Math.max(0,Math.round(r*0.3));
  const edgeG=Math.max(0,Math.round(g*0.3));
  const edgeB=Math.max(0,Math.round(b*0.3));

  const edgeSet=new Set();
  const uniqueEdges=[];
  visibleEdges.forEach(([a,b])=>{
    const key=Math.min(a,b)+'-'+Math.max(a,b);
    if(!edgeSet.has(key)){edgeSet.add(key);uniqueEdges.push([a,b]);}
  });

  // 搴曞眰鏆楃嚎
  ctx.strokeStyle=`rgba(${edgeR},${edgeG},${edgeB},0.85)`;
  ctx.lineWidth=2.0;
  ctx.lineCap='round';
  uniqueEdges.forEach(([a,b])=>{
    ctx.beginPath();ctx.moveTo(pts[a][0],pts[a][1]);ctx.lineTo(pts[b][0],pts[b][1]);ctx.stroke();
  });
  // 椤跺眰浜嚎锛堥珮鍏夎竟缂� 鈥� 澧炲己绔嬩綋鎰燂級
  const hiR=Math.min(255,r+50),hiG=Math.min(255,g+50),hiB=Math.min(255,b+50);
  ctx.strokeStyle=`rgba(${hiR},${hiG},${hiB},0.3)`;
  ctx.lineWidth=0.7;
  uniqueEdges.forEach(([a,b])=>{
    ctx.beginPath();ctx.moveTo(pts[a][0],pts[a][1]);ctx.lineTo(pts[b][0],pts[b][1]);ctx.stroke();
  });

  // 瑙掔偣鏍囪
  ctx.fillStyle=`rgba(${Math.min(255,r+30)},${Math.min(255,g+30)},${Math.min(255,b+30)},0.6)`;
  corners.forEach((_,i)=>{
    const p=pts[i];
    ctx.beginPath();ctx.arc(p[0],p[1],2,0,Math.PI*2);ctx.fill();
  });

  // ===== Hover 楂樹寒 鈥� 鍙戝厜鑴夊啿鏁堟灉 =====
  if(isHover){
    ctx.save();
    ctx.shadowColor='rgba(255,255,255,0.7)';ctx.shadowBlur=12;
    ctx.strokeStyle='rgba(255,255,255,0.85)';ctx.lineWidth=2.5;
    uniqueEdges.forEach(([a,b])=>{
      ctx.beginPath();ctx.moveTo(pts[a][0],pts[a][1]);ctx.lineTo(pts[b][0],pts[b][1]);ctx.stroke();
    });
    ctx.restore();
    // 瑙掔偣鏀惧ぇ
    ctx.fillStyle='rgba(255,255,255,0.9)';
    corners.forEach((_,i)=>{
      const p=pts[i];ctx.beginPath();ctx.arc(p[0],p[1],3.5,0,Math.PI*2);ctx.fill();
    });
  }
}

function checkHover(e){
  if(!result||!renderList.length){hoverIdx=-1;$('tooltip').style.display='none';return}
  const rect=canvas.getBoundingClientRect();
  if(rect.width===0||rect.height===0){hoverIdx=-1;$('tooltip').style.display='none';return}
  const mx=(e.clientX-rect.left)*(canvas.width/rect.width);
  const my=(e.clientY-rect.top)*(canvas.height/rect.height);
  let closest=-1,closestDist=1e9;
  const total=renderList.length;
  let showN=animState.progress>0?Math.ceil(animState.progress*total):total;
  const screenFactor=Math.min(W,H)/3000;

  for(let i=showN-1;i>=0&&i<total;i--){
    const item=renderList[i],p=item.pos;
    const pr=proj(p.x+p.w/2,p.y+p.h/2,p.z+p.d/2);
    const dx=mx-pr[0],dy=my-pr[1],dist=Math.sqrt(dx*dx+dy*dy);
    const hitR=Math.max(p.w,p.h,p.d)*zoom*screenFactor*0.4;
    if(dist<hitR&&dist<closestDist){closest=i;closestDist=dist;}
  }

  hoverIdx=closest;
  const tip=$('tooltip');
  if(closest>=0){
    const it=renderList[closest];
    tip.style.display='block';
    const cRect=canvas.parentElement.getBoundingClientRect();
    let left=e.clientX-cRect.left+15,top=e.clientY-cRect.top-80;
    const tw=tip.offsetWidth||200,th=tip.offsetHeight||100;
    if(left+tw>cRect.width)left=e.clientX-cRect.left-tw-15;
    if(top<0)top=e.clientY-cRect.top+15;
    tip.style.left=left+'px';tip.style.top=top+'px';
    tip.innerHTML=`<div class="tn">${esc(it.name)}</div>
      <div class="tr"><span class="tl">灏哄</span><span>${it.pos.w}脳${it.pos.d}脳${it.pos.h}mm</span></div>
      <div class="tr"><span class="tl">閲嶉噺</span><span>${it.wt}kg</span></div>
      <div class="tr"><span class="tl">浣嶇疆</span><span>(${it.pos.x}, ${it.pos.y}, ${it.pos.z})</span></div>
      <div class="tr"><span class="tl">浣撶Н</span><span>${(it.pos.w*it.pos.d*it.pos.h/1e9).toFixed(4)}m鲁</span></div>`;
  } else tip.style.display='none';
}

